generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  userProfilePK Int?      @unique
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BodyBattery {
  pk_date                      DateTime
  userProfilePK                Int
  calendarDate                 DateTime
  bodyBatteryVersion           Float?
  chargedValue                 Int?
  drainedValue                 Int?
  duringsleep_bodyBatteryStatus String?
  duringsleep_statTimestamp    DateTime?
  duringsleep_statsValue       Int?
  endofday_bodyBatteryStatus   String?
  endofday_statTimestamp       DateTime?
  endofday_statsValue          Int?
  highest_bodyBatteryStatus    String?
  highest_statTimestamp        DateTime?
  highest_statsValue           Int?
  lowest_bodyBatteryStatus     String?
  lowest_statTimestamp         DateTime?
  lowest_statsValue            Int?
  mostrecent_bodyBatteryStatus String?
  mostrecent_statTimestamp     DateTime?
  mostrecent_statsValue        Int?
  sleepend_bodyBatteryStatus   String?
  sleepend_statTimestamp       DateTime?
  sleepend_statsValue          Int?
  sleepstart_bodyBatteryStatus String?
  sleepstart_statTimestamp     DateTime?
  sleepstart_statsValue        Int?
  startofday_bodyBatteryStatus String?
  startofday_statTimestamp     DateTime?
  startofday_statsValue        Int?

  @@id([pk_date, userProfilePK])
  @@index([calendarDate])
  @@map("body_battery")
}

model Respiration {
  pk_date                  DateTime
  userProfilePK            Int
  calendarDate             DateTime
  algorithmVersion         Float?
  avgWakingRespirationValue Float?
  highestRespirationValue  Float?
  latestRespirationTimeGMT DateTime?
  latestRespirationValue   Float?
  lowestRespirationValue   Float?

  @@id([pk_date, userProfilePK])
  @@index([calendarDate])
  @@map("respiration")
}

model Stress {
  pk_date                             DateTime
  userProfilePK                       Int
  calendarDate                        DateTime
  asleep_activityDuration             Int?
  asleep_averageStressLevel           Float?
  asleep_averageStressLevelIntensity  Float?
  asleep_highDuration                 Int?
  asleep_lowDuration                  Int?
  asleep_maxStressLevel               Int?
  asleep_mediumDuration               Int?
  asleep_restDuration                 Int?
  asleep_stressDuration               Int?
  asleep_stressIntensityCount         Int?
  asleep_stressOffWristCount          Int?
  asleep_stressTooActiveCount         Int?
  asleep_totalDuration                Int?
  asleep_totalStressCount             Int?
  asleep_totalStressIntensity         Int?
  asleep_uncategorizedDuration        Int?
  awake_activityDuration              Int?
  awake_averageStressLevel            Float?
  awake_averageStressLevelIntensity   Float?
  awake_highDuration                  Int?
  awake_lowDuration                   Int?
  awake_maxStressLevel                Int?
  awake_mediumDuration                Int?
  awake_restDuration                  Int?
  awake_stressDuration                Int?
  awake_stressIntensityCount          Int?
  awake_stressOffWristCount           Int?
  awake_stressTooActiveCount          Int?
  awake_totalDuration                 Int?
  awake_totalStressCount              Int?
  awake_totalStressIntensity          Int?
  awake_uncategorizedDuration         Int?
  total_activityDuration              Int?
  total_averageStressLevel            Float?
  total_averageStressLevelIntensity   Float?
  total_highDuration                  Int?
  total_lowDuration                   Int?
  total_maxStressLevel                Int?
  total_mediumDuration                Int?
  total_restDuration                  Int?
  total_stressDuration                Int?
  total_stressIntensityCount          Int?
  total_stressOffWristCount           Int?
  total_stressTooActiveCount          Int?
  total_totalDuration                 Int?
  total_totalStressCount              Int?
  total_totalStressIntensity          Int?
  total_uncategorizedDuration         Int?

  @@id([pk_date, userProfilePK])
  @@index([calendarDate])
  @@map("sress")
}
